# Environment Variables untuk Vercel Deployment
# Copy nilai ini ke Vercel Dashboard > Project Settings > Environment Variables

# Supabase Configuration (REQUIRED)
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Application Configuration
NODE_ENV=production
VERCEL=1

# CORS Configuration
ALLOWED_ORIGINS=https://your-domain.vercel.app,https://www.your-domain.com

# Session Configuration
SESSION_SECRET=your_random_session_secret_here

# Optional: Google AI (jika menggunakan AI Assistant)
GOOGLE_AI_API_KEY=your_google_ai_key_here
